# Base de datos
DATABASE_URL=postgresql://user:password@host:port/dbname

# NextAuth
NEXTAUTH_SECRET=your-secret-here
# Dev local. En producción: NEXTAUTH_URL=https://agendapy.com.py
NEXTAUTH_URL=http://localhost:3000

# Dominio público para los links de reserva que se MUESTRAN/COMPARTEN (dashboard,
# onboarding). Debe coincidir con NEXTAUTH_URL. Se lee en el cliente (NEXT_PUBLIC_).
# Si falta, cae al dominio de producción (https://agendapy.com.py).
NEXT_PUBLIC_BASE_URL=https://agendapy.com.py

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twilio WhatsApp — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Cron job — generar con: openssl rand -hex 32
# Vercel lo envía automáticamente como "Authorization: Bearer <CRON_SECRET>" al disparar el cron
CRON_SECRET=your-cron-secret-here

# Twilio WhatsApp templates (opcional pero requerido en producción para mensajes
# iniciados por el negocio fuera de la ventana de 24h). Content SID de la plantilla aprobada.
# Si no se setean, se envían como texto plano (solo sirve en sandbox / dentro de 24h).
TWILIO_TEMPLATE_REMINDER_SID=
TWILIO_TEMPLATE_NEW_BOOKING_SID=
# Confirmación enviada AL CLIENTE apenas reserva (WhatsApp). Sin este SID se envía
# como texto plano (solo sirve en sandbox / dentro de la ventana de 24h).
TWILIO_TEMPLATE_CONFIRMATION_SID=

# Rate limiting durable (recomendado en Vercel serverless). Sin esto, el límite es
# por instancia (Map en memoria) y poco efectivo. Crear una DB Redis en Upstash.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Pool de conexiones de Prisma por instancia (default 10).
DATABASE_POOL_MAX=10

# Storage de imágenes (logo / portada) — Vercel Blob. En Vercel se inyecta solo al
# crear un Blob store (Storage → Create → Blob). Para dev local, copiá el token desde
# el dashboard de Vercel. Sin esta var, la subida responde 503 y el dueño puede pegar
# una URL manual como fallback (no se finge una subida exitosa).
BLOB_READ_WRITE_TOKEN=

# Zona horaria del negocio por defecto (se usa para "hoy"/"mañana" en slots y recordatorios).
APP_TIMEZONE=America/Asuncion

# Email transaccional (reset de contraseña + verificación). Si falta, los emails
# se loguean a consola en vez de enviarse (modo desarrollo).
# IMPORTANTE: Resend solo entrega desde un dominio VERIFICADO. En producción:
#   1) Agregá tu dominio en Resend (Domains → Add Domain).
#   2) Cargá los DNS que te da (SPF + DKIM).
#   3) Poné EMAIL_FROM con una casilla de ESE dominio.
# El default (agendapy.com.py) todavía NO está verificado → con API key real, Resend rechaza el envío.
RESEND_API_KEY=
EMAIL_FROM=Agendapy <no-reply@agendapy.com.py>

# Forzar verificación de email para login con credenciales. Default: desactivado.
# Poner en "true" SOLO cuando el envío de email funcione de verdad (RESEND_API_KEY +
# dominio verificado). Si se activa sin email funcional, nadie nuevo podrá iniciar sesión.
REQUIRE_EMAIL_VERIFICATION=false

# Observabilidad / alertas (opcional). Si se setea, lib/logger postea errores/warns
# a este endpoint. Auto-detecta webhooks de Slack/Discord y manda un mensaje legible
# a ese canal; con cualquier otra URL manda el registro JSON crudo (colector tipo Logtail).
# El fallo de entrega se loguea a consola (no se silencia). Sin la env, solo console.
#   - Slack:   https://hooks.slack.com/services/XXX  → alerta como mensaje
#   - Discord: https://discord.com/api/webhooks/XXX  → alerta como mensaje
#   - Otro:    cualquier colector que acepte POST JSON
LOG_SINK_URL=
# Token Bearer (solo para colectores JSON; Slack/Discord usan la URL como secreto).
LOG_SINK_TOKEN=
# Forzar formato del sink: slack | discord | json (default: auto por el host de la URL).
LOG_SINK_FORMAT=
